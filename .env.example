# ---- Required ----
TELEGRAM_BOT_TOKEN="REPLACE_WITH_YOURS"
GROQ_API_KEY="REPLACE_WITH_YOURS"     # or xai-... for xAI Grok
GEMINI_API_KEY="KEY1, KEY2, KEY3"    # Multi-key rotation support (comma separated)

# Whitelisted Telegram user IDs, comma separated. (e.g. 123456789,987654321)
WHITELISTED_USER_IDS=""

# ---- Firebase (Required for cloud memory) ----
# Paste the ENTIRE contents of your firebase-service-account.json as a single-line JSON string
FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# ---- Google Workspace Tools (Optional) ----
# Paste the contents of your credentials.json (OAuth2 client) as a JSON string
GOOGLE_CREDENTIALS='{"installed":{"client_id":"...","client_secret":"...","redirect_uris":[...]}}'

# Paste the contents of your token.json (OAuth2 access + refresh tokens) as a JSON string
# Run locally first to generate this, then copy the file contents here
GOOGLE_TOKEN='{"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}'

# ---- Misc ----
NODE_ENV=production
